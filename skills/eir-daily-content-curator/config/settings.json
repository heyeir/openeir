{
  "mode": "standalone",
  "skill_version": "1.0.0",
  "supported_schema_versions": ["2"],
  "max_items_per_day": 10,
  "local_storage": "data/",

  "search": {
    "grounding_base_url": "https://api.example-grounding.com/v3",
    "grounding_api_key": "YOUR_API_KEY_HERE",
    "providers": ["tavily", "brave"],
    "searxng_url": "http://localhost:8888",
    "crawl4ai_url": "http://localhost:11235",
    "search_gateway_url": null
  },

  "rss_sources": "config/sources.json",

  "cron": {
    "schedule": "0 8 * * *",
    "timezone": "UTC"
  },

  "eir": {
    "bilingual": false,
    "sync_interests": true,
    "post_content": true,
    "extract_whispers": true
  }
}
